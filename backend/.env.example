# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
# Full connection string — used by the app and the migration runner
DATABASE_URL=postgresql://lendly:lendly_secret@localhost:5432/lendly_dev

# Individual values — used by docker-compose to initialise the container
POSTGRES_DB=lendly_dev
POSTGRES_USER=lendly
POSTGRES_PASSWORD=lendly_secret
POSTGRES_PORT=5432

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Frontend origin allowed by CORS (development default below)
CORS_ORIGIN=http://localhost:5173

# Base URL used to construct links in emails
BASE_URL=http://localhost:3000

# ── Auth (Phase 2) ────────────────────────────────────────────────────────────
# Generate secure values with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_with_a_long_random_hex_string
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_hex_string

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Email / SMTP (Phase 2) ────────────────────────────────────────────────────
# For local development, leave SMTP_USER empty to use auto-generated Ethereal
# accounts (preview URLs will be logged to the console).
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@lendly.app

# ── Storage (Phase 3) ─────────────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=lendly-assets
